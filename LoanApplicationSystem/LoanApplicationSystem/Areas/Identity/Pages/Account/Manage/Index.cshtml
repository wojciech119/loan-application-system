@page
@model IndexModel

@{
    ViewData["Title"] = "Profil";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h2>Profil użytkownika</h2>

<p>
    Podstawowe informacje przypisane do konta użytkownika.
</p>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="Username" class="form-label">Nazwa użytkownika</label>
                <input asp-for="Username" class="form-control" disabled />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.PhoneNumber" class="form-label">Numer telefonu</label>
                <input asp-for="Input.PhoneNumber" class="form-control" />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary">
                Zapisz
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}