@page
@model LoginModel

@{
    ViewData["Title"] = "Logowanie";
}

<div class="auth-panel">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <h1 class="mb-2">Logowanie</h1>

                    <p class="mb-4">
                        Zaloguj się na konto użytkownika systemu.
                    </p>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="pracownik@bank.pl" />
                            <label asp-for="Input.Email">Adres e-mail</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   placeholder="Hasło" />
                            <label asp-for="Input.Password">Hasło</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="checkbox mb-3">
                            <label asp-for="Input.RememberMe">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                Zapamiętaj mnie
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">
                            Zaloguj
                        </button>

                        <div class="mt-4 d-grid gap-2">
                            <a id="forgot-password" asp-page="./ForgotPassword">
                                Nie pamiętasz hasła?
                            </a>

                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                                Zarejestruj nowego użytkownika
                            </a>

                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">
                                Wyślij ponownie potwierdzenie e-mail
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}