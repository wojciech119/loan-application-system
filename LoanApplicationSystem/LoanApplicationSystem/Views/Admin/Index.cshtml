@model IEnumerable<LoanApplicationSystem.Models.LoanApplication>

@{
    ViewData["Title"] = "Panel administratora";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Panel administratora</h1>
        <p class="text-muted mb-0">
            Zarządzanie wnioskami kredytowymi klientów.
        </p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-2 mb-3">
        <div class="card text-center h-100 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Wszystkie</h6>
                <h2>@ViewBag.TotalCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-2 mb-3">
        <div class="card text-center h-100 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Złożone</h6>
                <h2>@ViewBag.NewCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center h-100 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">W analizie</h6>
                <h2>@ViewBag.InProgressCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-2 mb-3">
        <div class="card text-center h-100 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Zaakceptowane</h6>
                <h2>@ViewBag.AcceptedCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center h-100 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Odrzucone</h6>
                <h2>@ViewBag.RejectedCount</h2>
            </div>
        </div>
    </div>
</div>

<form method="get" class="card card-body mb-4 shadow-sm">
    <div class="row">
        <div class="col-md-5 mb-3">
            <label class="form-label">Szukaj</label>
            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Imię, e-mail, telefon, cel kredytu..." />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Status</label>

            <select name="status" class="form-select">
                @if (string.IsNullOrEmpty(ViewBag.Status))
                {
                    <option value="" selected>Wszystkie</option>
                }
                else
                {
                    <option value="">Wszystkie</option>
                }

                @foreach (var statusItem in new[] { "Złożony", "W trakcie analizy", "Zaakceptowany", "Odrzucony", "Wymaga uzupełnienia" })
                {
                    if (ViewBag.Status == statusItem)
                    {
                        <option value="@statusItem" selected>@statusItem</option>
                    }
                    else
                    {
                        <option value="@statusItem">@statusItem</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3 mb-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">
                Filtruj
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Wyczyść
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Brak wniosków spełniających podane kryteria.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Numer</th>
                    <th>Klient</th>
                    <th>E-mail</th>
                    <th>Kwota</th>
                    <th>Status</th>
                    <th>Wynik</th>
                    <th>Data</th>
                    <th>Akcje</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.RequestedAmount.ToString("N2") zł</td>

                        <td>
                            @if (item.Status == "Zaakceptowany")
                            {
                                <span class="badge bg-success">@item.Status</span>
                            }
                            else if (item.Status == "Odrzucony")
                            {
                                <span class="badge bg-danger">@item.Status</span>
                            }
                            else if (item.Status == "W trakcie analizy")
                            {
                                <span class="badge bg-warning text-dark">@item.Status</span>
                            }
                            else if (item.Status == "Wymaga uzupełnienia")
                            {
                                <span class="badge bg-info text-dark">@item.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.Status</span>
                            }
                        </td>

                        <td>@item.CreditScore / 100</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>

                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                Obsłuż
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}