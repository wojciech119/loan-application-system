@model LoanApplicationSystem.Models.LoanApplication

@{
    ViewData["Title"] = "Szczegóły wniosku";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Szczegóły wniosku #@Model.Id</h1>

    <a asp-action="Index" class="btn btn-dark">
        Powrót
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                Dane klienta i kredytu
            </div>

            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Klient</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>

                    <dt class="col-sm-4">E-mail</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Telefon</dt>
                    <dd class="col-sm-8">@Model.PhoneNumber</dd>

                    <dt class="col-sm-4">Dochód netto</dt>
                    <dd class="col-sm-8">@Model.MonthlyIncome.ToString("N2") zł</dd>

                    <dt class="col-sm-4">Zobowiązania</dt>
                    <dd class="col-sm-8">@Model.MonthlyExpenses.ToString("N2") zł</dd>

                    <dt class="col-sm-4">Dochód rozporządzalny</dt>
                    <dd class="col-sm-8">@Model.DisposableIncome.ToString("N2") zł</dd>

                    <dt class="col-sm-4">Kwota kredytu</dt>
                    <dd class="col-sm-8">@Model.RequestedAmount.ToString("N2") zł</dd>

                    <dt class="col-sm-4">Okres spłaty</dt>
                    <dd class="col-sm-8">@Model.RepaymentMonths miesięcy</dd>

                    <dt class="col-sm-4">Szacowana rata</dt>
                    <dd class="col-sm-8">@Model.EstimatedMonthlyInstallment.ToString("N2") zł</dd>

                    <dt class="col-sm-4">DTI</dt>
                    <dd class="col-sm-8">@Model.DtiPercent.ToString("N2") %</dd>

                    <dt class="col-sm-4">Wynik scoringowy</dt>
                    <dd class="col-sm-8">@Model.CreditScore / 100</dd>

                    <dt class="col-sm-4">Rekomendacja systemu</dt>
                    <dd class="col-sm-8">
                        @if (Model.CreditDecision == "Zdolność kredytowa pozytywna")
                        {
                            <span class="badge bg-success">@Model.CreditDecision</span>
                        }
                        else if (Model.CreditDecision == "Zdolność kredytowa warunkowa")
                        {
                            <span class="badge bg-warning text-dark">@Model.CreditDecision</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@Model.CreditDecision</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Zatrudnienie</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(x => x.EmploymentType)</dd>

                    <dt class="col-sm-4">Historia kredytowa</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(x => x.CreditHistory)</dd>

                    <dt class="col-sm-4">Osoby na utrzymaniu</dt>
                    <dd class="col-sm-8">@Model.Dependents</dd>

                    <dt class="col-sm-4">Nieruchomość</dt>
                    <dd class="col-sm-8">@(Model.HasProperty ? "Tak" : "Nie")</dd>

                    <dt class="col-sm-4">Cel kredytu</dt>
                    <dd class="col-sm-8">@Model.Purpose</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-4">Data utworzenia</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                Historia decyzji
            </div>

            <div class="card-body">
                @if (!Model.DecisionHistory.Any())
                {
                    <div class="alert alert-info mb-0">
                        Brak zmian statusu dla tego wniosku.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Poprzedni status</th>
                                    <th>Nowy status</th>
                                    <th>Komentarz</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model.DecisionHistory.OrderByDescending(x => x.ChangedAt))
                                {
                                    <tr>
                                        <td>@item.ChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@item.OldStatus</td>
                                        <td>@item.NewStatus</td>
                                        <td>@item.Comment</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                Ocena systemowa
            </div>

            <div class="card-body">
                <p>
                    <strong>Scoring:</strong>
                </p>

                <div class="progress mb-3">
                    <div class="progress-bar"
                         role="progressbar"
                         style="width: @Model.CreditScore%;"
                         aria-valuenow="@Model.CreditScore"
                         aria-valuemin="0"
                         aria-valuemax="100">
                        @Model.CreditScore / 100
                    </div>
                </div>

                <p>
                    <strong>Rekomendacja:</strong>
                </p>

                @if (Model.CreditDecision == "Zdolność kredytowa pozytywna")
                {
                    <div class="alert alert-success">
                        @Model.CreditDecision
                    </div>
                }
                else if (Model.CreditDecision == "Zdolność kredytowa warunkowa")
                {
                    <div class="alert alert-warning">
                        @Model.CreditDecision
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        @Model.CreditDecision
                    </div>
                }

                <hr />

                <p><strong>Dochód rozporządzalny:</strong></p>
                <p>@Model.DisposableIncome.ToString("N2") zł</p>

                <p><strong>Szacowana rata:</strong></p>
                <p>@Model.EstimatedMonthlyInstallment.ToString("N2") zł</p>

                <p><strong>DTI:</strong></p>
                <p>@Model.DtiPercent.ToString("N2") %</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                Decyzja przełożonego
            </div>

            <div class="card-body">
                <p>
                    <strong>Aktualny status:</strong>
                </p>

                <span class="badge bg-secondary fs-6 mb-3">
                    @Model.Status
                </span>

                <form asp-action="ChangeStatus" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="form-group mb-3">
                        <label for="newStatus">Nowy status</label>
                        <select name="newStatus" id="newStatus" class="form-select">
                            <option value="Złożony">Złożony</option>
                            <option value="W trakcie analizy">W trakcie analizy</option>
                            <option value="Wymaga uzupełnienia">Wymaga uzupełnienia</option>
                            <option value="Zaakceptowany">Zaakceptowany</option>
                            <option value="Odrzucony">Odrzucony</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label for="comment">Komentarz</label>
                        <textarea name="comment"
                                  id="comment"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Wpisz komentarz do decyzji"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Zapisz decyzję
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>