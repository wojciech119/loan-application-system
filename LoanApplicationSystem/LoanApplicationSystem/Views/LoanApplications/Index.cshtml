@model IEnumerable<LoanApplicationSystem.Models.LoanApplication>

@{
    ViewData["Title"] = "Wnioski pracownika";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Wnioski obsługiwane przez pracownika</h1>
        <p class="text-muted mb-0">
            Lista zawiera wnioski klientów utworzone przez aktualnie zalogowanego pracownika banku.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Nowy wniosek klienta
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nie utworzono jeszcze żadnych wniosków klientów.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Numer</th>
                    <th>Klient</th>
                    <th>Kwota kredytu</th>
                    <th>Szacowana rata</th>
                    <th>DTI</th>
                    <th>Scoring</th>
                    <th>Rekomendacja</th>
                    <th>Status</th>
                    <th>Data</th>
                    <th>Akcje</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.FullName</td>
                        <td>@item.RequestedAmount.ToString("N2") zł</td>
                        <td>@item.EstimatedMonthlyInstallment.ToString("N2") zł</td>
                        <td>@item.DtiPercent.ToString("N2") %</td>
                        <td>@item.CreditScore / 100</td>

                        <td>
                            @if (item.CreditDecision == "Zdolność kredytowa pozytywna")
                            {
                                <span class="badge bg-success">@item.CreditDecision</span>
                            }
                            else if (item.CreditDecision == "Zdolność kredytowa warunkowa")
                            {
                                <span class="badge bg-warning text-dark">@item.CreditDecision</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@item.CreditDecision</span>
                            }
                        </td>

                        <td>
                            @if (item.Status == "Zaakceptowany")
                            {
                                <span class="badge bg-success">@item.Status</span>
                            }
                            else if (item.Status == "Odrzucony")
                            {
                                <span class="badge bg-danger">@item.Status</span>
                            }
                            else if (item.Status == "W trakcie analizy")
                            {
                                <span class="badge bg-warning text-dark">@item.Status</span>
                            }
                            else if (item.Status == "Wymaga uzupełnienia")
                            {
                                <span class="badge bg-info text-dark">@item.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.Status</span>
                            }
                        </td>

                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>

                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                Szczegóły
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}