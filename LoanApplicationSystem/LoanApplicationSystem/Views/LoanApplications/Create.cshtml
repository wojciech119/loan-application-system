@model LoanApplicationSystem.Models.LoanApplication

@{
    ViewData["Title"] = "Nowy wniosek klienta";
}

<h1>Nowy wniosek kredytowy klienta</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            Dane klienta
        </div>

        <div class="card-body">
            <div class="form-group mb-3">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email"
                       class="form-control"
                       placeholder="np. jan.kowalski@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber"
                       class="form-control"
                       placeholder="np. 500 600 700" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            Dane finansowe
        </div>

        <div class="card-body">
            <div class="form-group mb-3">
                <label asp-for="MonthlyIncome"></label>
                <input asp-for="MonthlyIncome"
                       class="form-control money-input"
                       type="text"
                       inputmode="decimal"
                       placeholder="np. 12000 albo 12 000"
                       data-val="false" />
                <span asp-validation-for="MonthlyIncome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MonthlyExpenses"></label>
                <input asp-for="MonthlyExpenses"
                       class="form-control money-input"
                       type="text"
                       inputmode="decimal"
                       placeholder="np. 2000 albo 2 000"
                       data-val="false" />
                <span asp-validation-for="MonthlyExpenses" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RequestedAmount"></label>
                <input asp-for="RequestedAmount"
                       class="form-control money-input"
                       type="text"
                       inputmode="decimal"
                       placeholder="np. 100000 albo 100 000"
                       data-val="false" />
                <span asp-validation-for="RequestedAmount" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RepaymentMonths"></label>
                <input asp-for="RepaymentMonths" class="form-control" />
                <span asp-validation-for="RepaymentMonths" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Purpose"></label>
                <textarea asp-for="Purpose"
                          class="form-control"
                          rows="3"></textarea>
                <span asp-validation-for="Purpose" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            Dane scoringowe
        </div>

        <div class="card-body">
            <div class="form-group mb-3">
                <label asp-for="EmploymentType"></label>
                <select asp-for="EmploymentType"
                        class="form-select"
                        asp-items="Html.GetEnumSelectList<EmploymentType>()">
                    <option value="">-- wybierz --</option>
                </select>
                <span asp-validation-for="EmploymentType" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CreditHistory"></label>
                <select asp-for="CreditHistory"
                        class="form-select"
                        asp-items="Html.GetEnumSelectList<CreditHistory>()">
                    <option value="">-- wybierz --</option>
                </select>
                <span asp-validation-for="CreditHistory" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Dependents"></label>
                <input asp-for="Dependents" class="form-control" />
                <span asp-validation-for="Dependents" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="HasProperty" class="form-check-input" />
                <label asp-for="HasProperty" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">
        Zapisz wniosek i oblicz zdolność kredytową
    </button>

    <a asp-action="Index" class="btn btn-dark">
        Anuluj
    </a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $("form").on("submit", function () {
            $(".money-input").each(function () {
                var value = $(this).val();

                if (value) {
                    value = value
                        .replace(/\s/g, "")
                        .replace(/\u00A0/g, "")
                        .replace(/\u202F/g, "");

                    $(this).val(value);
                }
            });
        });
    </script>
}