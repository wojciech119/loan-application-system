@page
@model EmailModel

@{
    ViewData["Title"] = "Adres e-mail";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<h2>Adres e-mail</h2>

<p>
    W tym miejscu możesz sprawdzić lub zmienić adres e-mail przypisany do konta.
</p>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form id="email-form" method="post">
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" disabled />
                <label asp-for="Email">Aktualny adres e-mail</label>
            </div>

            @if (!Model.IsEmailConfirmed)
            {
                <button id="email-verification"
                        type="submit"
                        asp-page-handler="SendVerificationEmail"
                        class="btn btn-outline-primary mb-3">
                    Wyślij wiadomość weryfikacyjną
                </button>
            }

            <div class="form-floating mb-3">
                <input asp-for="Input.NewEmail"
                       class="form-control"
                       autocomplete="email"
                       aria-required="true"
                       placeholder="nowy@bank.pl" />
                <label asp-for="Input.NewEmail">Nowy adres e-mail</label>
                <span asp-validation-for="Input.NewEmail" class="text-danger"></span>
            </div>

            <button id="change-email-button"
                    type="submit"
                    asp-page-handler="ChangeEmail"
                    class="btn btn-primary">
                Zmień adres e-mail
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}